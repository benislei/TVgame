{
  "name": "lan-game-streaming-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "Low-latency LAN game streaming prototype using WebRTC, WebSocket signaling, and a DXGI capture module skeleton.",
  "scripts": {
    "signal": "node src/signaling-server.js",
    "sender": "node src/sender.js",
    "capture:preview": "node src/capture/preview-server.js",
    "native:check": "node src/native-streamer/cli.js check",
    "native:install": "node src/native-streamer/cli.js install",
    "native:pipeline": "node src/native-streamer/cli.js pipeline",
    "native:profiles": "node src/native-streamer/cli.js profiles",
    "native:run": "node src/native-streamer/cli.js run",
    "stage2:check": "node src/native-streamer/cli.js stage2-check",
    "stage2:doctor": "node src/native-streamer/cli.js stage2-doctor",
    "native:rtp": "node src/native-streamer/cli.js rtp",
    "android:check": "node src/android-build/cli.js check",
    "android:install": "node src/android-build/cli.js install",
    "android:build": "node src/android-build/cli.js build",
    "android:apk": "node src/android-build/cli.js apk",
    "package:friend": "node src/release-package/cli.js friend",
    "desktop": "electron src/desktop/main.js",
    "desktop:package": "electron-builder --config src/desktop/electron-builder.json",
    "test": "node --test"
  },
  "dependencies": {
    "ws": "^8.17.1"
  },
  "optionalDependencies": {
    "@roamhq/wrtc": "^0.10.0",
    "naudiodon": "^2.4.2",
    "wrtc": "^0.4.7"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  }
}
