{
  "appId": "com.tvgame.sender",
  "productName": "TVGame Sender",
  "directories": {
    "output": "dist-desktop"
  },
  "asar": false,
  "extraMetadata": {
    "main": "src/desktop/main.js"
  },
  "electronDownload": {
    "mirrorOptions": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    }
  },
  "files": [
    "package.json",
    "src/**",
    "scripts/**",
    "InputBridgeRuntime/**",
    "InputBridge/**",
    "docs/**",
    "public/**",
    "!node_modules/**",
    "!dist/**",
    "!dist-desktop/**",
    "!build/**",
    "!InputBridge/bin/**",
    "!InputBridge/obj/**"
  ],
  "win": {
    "target": [
      "portable"
    ]
  }
}
